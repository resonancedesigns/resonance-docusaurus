{
  "name": "docusaurus-template",
  "version": "1.0.0",
  "description": "A comprehensive Docusaurus 3.8.1 template with TypeScript, advanced theming, commenting system, and automated build processes",
  "private": false,
  "license": "MIT",
  "author": "The-Running-Dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Running-Dev/Docusaurus-Template.git"
  },
  "bugs": {
    "url": "https://github.com/The-Running-Dev/Docusaurus-Template/issues"
  },
  "homepage": "https://github.com/The-Running-Dev/Docusaurus-Template#readme",
  "keywords": [
    "docusaurus",
    "documentation",
    "template",
    "typescript",
    "react",
    "markdown",
    "themes",
    "giscus",
    "comments"
  ],
  "scripts": {
    "docusaurus": "docusaurus",
    "// PRE-BUILD SCRIPTS": "",
    "prebuild": "tsx --tsconfig ./scripts/tsconfig.json ./scripts/pre-build.ts",
    "prebuild:prod": "cross-env NODE_ENV=production tsx --tsconfig ./scripts/tsconfig.json ./scripts/pre-build.ts",
    "prebuild:check": "tsc --project ./scripts/tsconfig.json --noEmit",
    "// DEVELOPMENT SCRIPTS": "",
    "prestart": "pnpm run prebuild",
    "start": "docusaurus start",
    "prestart:docker": "pnpm run prebuild",
    "start:docker": "concurrently \"pnpm run watch:config\" \"docusaurus start --host 0.0.0.0 --port 3000\"",
    "prestart:debug": "pnpm run prebuild",
    "start:debug": "docusaurus start",
    "dev": "concurrently \"pnpm run watch:config\" \"pnpm run start:debug\"",
    "watch:config": "chokidar \"config/**/*.{yml,yaml}\" -c \"tsx --tsconfig ./scripts/tsconfig.json ./scripts/pre-build.ts\"",
    "// BUILD SCRIPTS": "",
    "prebuild:build": "pnpm run prebuild",
    "build": "pnpm run prebuild && docusaurus build --out-dir ./artifacts",
    "build:prod": "pnpm run prebuild:prod && docusaurus build --out-dir ./artifacts",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "// DOCUSAURUS UTILITIES": "",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "// TESTING & VALIDATION": "",
    "test": "pnpm run test:run",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --reporter=dot",
    "test:fail": "vitest run --reporter=dot",
    "test:bail": "vitest run --reporter=verbose --bail=1",
    "test:components": "vitest run --coverage src/components",
    "test:ci": "pnpm run test:coverage",
    "test:all": "pnpm run test:run && pnpm run typecheck && pnpm run validate:config && pnpm run validate:schemas",
    "typecheck": "tsc --noEmit",
    "validate:config": "tsx --tsconfig ./scripts/tsconfig.json ./scripts/validate-github-config.ts",
    "validate:schemas": "tsx --tsconfig ./scripts/tsconfig.json ./scripts/test-schema-system.ts",
    "// CODE QUALITY": "",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run prebuild:check && pnpm run validate:config",
    "quality:fix": "pnpm run format && pnpm run lint:fix",
    "quality-ci": "pnpm run lint && pnpm run typecheck && pnpm run prebuild:check",
    "// API": "",
    "api:dev": "pnpm --dir api dev",
    "api:start": "pnpm --dir api start",
    "dev:with-api": "concurrently \"pnpm api:dev\" \"pnpm dev\"",
    "// SETUP": "",
    "prepare": "husky"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.1",
    "@docusaurus/preset-classic": "3.9.1",
    "@docusaurus/theme-classic": "3.9.1",
    "@docusaurus/theme-common": "3.9.1",
    "@docusaurus/theme-mermaid": "3.9.1",
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "@fortawesome/free-brands-svg-icons": "^7.0.0",
    "@fortawesome/free-solid-svg-icons": "^7.0.0",
    "@fortawesome/react-fontawesome": "^0.2.3",
    "@giscus/react": "^3.1.0",
    "@mdx-js/react": "^3.0.0",
    "@types/react-router-dom": "^5.3.3",
    "clsx": "^2.0.0",
    "cross-env": "^10.0.0",
    "js-yaml": "^4.1.0",
    "jwt-decode": "^4.0.0",
    "markdown-to-jsx": "^7.7.12",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.2",
    "react-toastify": "^11.0.5",
    "zod": "^4.0.16",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.1",
    "@docusaurus/tsconfig": "3.9.1",
    "@docusaurus/types": "3.9.1",
    "@eslint/js": "^9.32.0",
    "@rollup/rollup-linux-x64-gnu": "4.46.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.9",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.7",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.0.7"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
