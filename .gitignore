# =============================================================================
# NODE.JS / NPM / PNPM / YARN
# =============================================================================

# Dependency directories
jspm_packages/
node_modules/
.pnpm-store/
web_modules/

# Package manager files
.npm
.yarn-integrity
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Package outputs
*.tgz

# =============================================================================
# LOGS AND DIAGNOSTICS
# =============================================================================

# Logs
*.log
lerna-debug.log*
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
*.pid
*.pid.lock
*.seed
pids

# Optional REPL history
.node_repl_history

# TernJS port file
.tern-port

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# =============================================================================
# BUILD OUTPUTS AND CACHES
# =============================================================================

# General cache directories
.cache
.cache/
.parcel-cache
.temp

# Build outputs
build/
build/Release
dist
out

# Coverage and testing
*.lcov
coverage
.nyc_output

# TypeScript cache
*.tsbuildinfo

# Tool-specific caches
.eslintcache
.fusebox/
.grunt
.stylelintcache

