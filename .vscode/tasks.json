{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open Terminal in Project Root",
            "type": "shell",
            "command": "echo",
            "args": ["Opening terminal in project directory..."],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new"
            }
        },
        {
            "label": "verify",
            "type": "shell",
            "command": "npm run verify",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$tsc", "$eslint-stylish"]
        },
        {
            "label": "test",
            "type": "shell",
            "command": "npm test --silent",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$ts-jest"] 
        },
        {
            "label": "build",
            "type": "shell",
            "command": "npm run build",
            "options": { "cwd": "${workspaceFolder}" }
        }
    ]
}